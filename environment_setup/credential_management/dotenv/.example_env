AGO_BM_EDITOR_PASS = "password"

AGO_DSS_CREATOR_UNAME = "user-name"
AGO_DSS_CREATOR_PASS = "password"

# GIT HUB ACCOUNTS
# ------------------------------------------------------------------------------
GHUB_BM_ABMS_UNAME = "user-name"
GHUB_BM_ABMS_PASS = "password"

# PMBC ICD
# ------------------------------------------------------------------------------
PMBC_USR_NAME = "user-name"
PMBC_PROD_PWD = "password"
PMBC_TEST_PWD = "password"
