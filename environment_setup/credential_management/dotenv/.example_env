# Notice the naming scheme that helps to keep it organzied. These names will show up in code
# that calls them as well. The naming helps to make it clear what is getting accessed in the code.
 
# All Cap section headers are helpful
# ########################### 

# OBJECT STORAGE
# ------------------------------------------------------------------------------
S3_BMRS_HOST = "https://web.address.ca"
S3_BMRS_BUCKET_01 = "bucketid"
S3_BMRS_ACCESS_KEY_ID = "access-key-code"
S3_BMRS_SECRET_KEY = "secret-key"

# AGO PROXY ACCTS
# ------------------------------------------------------------------------------
